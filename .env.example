# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/warkop?retryWrites=true&w=majority
MONGODB_DB=warkop

# JWT Secret Key (generate a strong random string for production)
JWT_SECRET=your-secret-key-change-this-in-production

# Optional: Use public DNS (8.8.8.8) for MongoDB connection on Windows
# MONGODB_USE_PUBLIC_DNS=1
