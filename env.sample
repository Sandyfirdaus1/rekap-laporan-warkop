# Salin ke .env.local
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=warkop

# Jika error: querySrv ECONNREFUSED (DNS SRV gagal di Windows), coba baris ini:
# MONGODB_USE_PUBLIC_DNS=1

# Alternatif: di Atlas → Connect → Drivers, pakai "standard connection string"
# (mongodb://host1:27017,host2:27017,... bukan mongodb+srv) lalu tempel ke MONGODB_URI.
